# Local backend environment example
# Copy this file to .env and adjust values for your environment.
# For Atlas, set MONGO_URI to your MongoDB connection string.
# Example:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.1kd9e0b.mongodb.net/?appName=Cluster0

MONGO_URI=mongodb://127.0.0.1:27017/raahesystem
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=8h
FRONTEND_ORIGIN=http://localhost:5173

# Optional Twilio settings for SMS OTP if you configure Twilio.
#TWILIO_SID=your_twilio_sid
#TWILIO_AUTH_TOKEN=your_twilio_auth_token
#TWILIO_FROM=+1234567890
